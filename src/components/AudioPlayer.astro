---
interface Props {
  src: string;
  title?: string;
  caption?: string;
}
const { src, title = 'Listen to this article', caption } = Astro.props;
---

<figure class="audio">
  <figcaption class="audio-head">
    <span class="audio-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 10v4h4l5 5V5L7 10H3z" />
        <path d="M16.5 8.5a5 5 0 0 1 0 7" />
        <path d="M19.5 5.5a9 9 0 0 1 0 13" />
      </svg>
    </span>
    <span class="audio-title">{title}</span>
  </figcaption>
  <audio controls preload="none" src={src}>
    Your browser does not support the audio element.
    <a href={src}>Download the audio</a>.
  </audio>
  {caption && <p class="audio-caption">{caption}</p>}
</figure>

<style>
  .audio {
    margin: 2rem 0;
    padding: 1.1rem 1.2rem 1.2rem;
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    border-radius: var(--radius);
  }
  .audio-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
    color: var(--accent-deep);
  }
  .audio-icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: #fff;
    color: var(--accent);
    flex: none;
  }
  .audio audio { width: 100%; display: block; }
  .audio-caption {
    margin: 0.7rem 0 0;
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
</style>
