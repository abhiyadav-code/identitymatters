---
import { url } from '../lib/url';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  heroAlt?: string;
  hasAudio?: boolean;
}
const { href, title, description, pubDate, heroImage, heroAlt, hasAudio } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={url(href)} class="card post-card">
  {heroImage && (
    <div class="post-thumb">
      <img src={url(heroImage)} alt={heroAlt ?? ''} width="720" height="420" loading="lazy" decoding="async" />
    </div>
  )}
  <div class="post-body">
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      {hasAudio && <span class="badge">🎧 Audio</span>}
    </div>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
    <span class="post-more">Read article →</span>
  </div>
</a>

<style>
  .post-card { display: flex; flex-direction: column; overflow: hidden; height: 100%; }
  .post-thumb { aspect-ratio: 16 / 9; overflow: hidden; background: var(--accent-soft); }
  .post-thumb :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .post-body { padding: 1.25rem 1.35rem 1.4rem; display: flex; flex-direction: column; flex: 1; }
  .post-meta {
    display: flex; align-items: center; gap: 0.7rem;
    font-size: 0.82rem; color: var(--ink-faint); margin-bottom: 0.55rem;
  }
  .badge {
    font-size: 0.72rem; font-weight: 600; color: var(--accent-deep);
    background: var(--accent-soft); padding: 0.1rem 0.5rem; border-radius: 999px;
  }
  .post-title { font-size: 1.25rem; margin: 0 0 0.5rem; color: var(--ink); }
  .post-desc { color: var(--ink-soft); font-size: 0.96rem; margin: 0 0 1rem; flex: 1; }
  .post-more { color: var(--accent-deep); font-weight: 600; font-size: 0.9rem; }
</style>
