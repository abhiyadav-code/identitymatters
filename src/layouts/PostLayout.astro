---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, heroAlt, audio } = post.data;

const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="section-tight">
    <div class="container post-head">
      <a href="/writing" class="back-link">← All writing</a>
      <p class="eyebrow">Article</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <p class="post-byline">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {updatedDate && <span> · Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
        <span> · Abhi Yadav</span>
      </p>
    </div>

    {heroImage && (
      <div class="container post-hero">
        <img src={heroImage} alt={heroAlt ?? ''} width="1200" height="675" />
      </div>
    )}

    <div class="container">
      <div class="prose post-body">
        {audio && <AudioPlayer src={audio} caption="Prefer to listen? Press play above." />}
        <slot />
      </div>
    </div>

    <div class="container">
      <hr class="rule prose" />
      <p class="prose muted post-foot">
        Thanks for reading. For more essays and talks on digital identity, visit the
        <a href="/writing">writing index</a> or see where I'm <a href="/speaking">speaking</a>.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .post-head { max-width: var(--maxw-prose); }
  .back-link { font-size: 0.9rem; font-weight: 550; display: inline-block; margin-bottom: 1.5rem; }
  .post-byline { color: var(--ink-faint); font-size: 0.92rem; margin-top: 0.5rem; }
  .post-hero {
    margin-block: 2rem;
  }
  .post-hero :global(img) {
    width: 100%; height: auto; border-radius: var(--radius);
    box-shadow: var(--shadow-soft); border: 1px solid var(--line);
  }
  .post-body { font-size: 1.09rem; }
  .post-body :global(h2) { margin-top: 2.2rem; }
  .post-body :global(h3) { margin-top: 1.8rem; }
  .post-body :global(img) {
    border-radius: var(--radius); border: 1px solid var(--line);
    box-shadow: var(--shadow-soft); margin-block: 1.5rem;
  }
  .post-body :global(blockquote) {
    margin: 1.6rem 0; padding: 0.6rem 0 0.6rem 1.4rem;
    border-left: 3px solid var(--accent);
    color: var(--ink-soft); font-style: italic;
  }
  .post-body :global(pre) {
    padding: 1.1rem 1.25rem; border-radius: var(--radius-sm);
    border: 1px solid var(--line); overflow-x: auto; font-size: 0.92rem;
  }
  .post-body :global(code):not(:global(pre code)) {
    background: var(--accent-soft); padding: 0.12em 0.4em;
    border-radius: 5px; font-size: 0.9em;
  }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.3rem; }
  .post-body :global(li) { margin-bottom: 0.4rem; }
  .post-foot { font-size: 0.96rem; }
</style>
