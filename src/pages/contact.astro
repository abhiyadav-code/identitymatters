---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { label: 'LinkedIn', value: 'in/abhiyadav', href: 'https://www.linkedin.com/in/abhiyadav/' },
  { label: 'Email', value: 'hello@identitymatters.blog', href: 'mailto:hello@identitymatters.blog' },
  { label: 'Twitter / X', value: '@identitymatters', href: 'https://twitter.com/' },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Abhi Yadav about identity & access management, speaking, or collaboration."
>
  <section class="section-tight">
    <div class="container page-head prose">
      <p class="eyebrow">Contact</p>
      <h1>Let’s talk identity</h1>
      <p class="lede">
        Comparing notes, a speaking invitation, or a question about something I’ve
        written — I’d love to hear from you.
      </p>

      <ul class="contact-list">
        {links.map((l) => (
          <li class="contact-row">
            <span class="contact-label">{l.label}</span>
            <a href={l.href} rel="noopener">{l.value}</a>
          </li>
        ))}
      </ul>

      <p class="muted contact-note">
        This site is intentionally read-only — no comments or trackers. The
        quickest way to reach me is LinkedIn or email.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { max-width: var(--maxw-prose); }
  .contact-list { list-style: none; margin: 2rem 0 0; padding: 0; }
  .contact-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.9rem 0;
    border-top: 1px solid var(--line);
  }
  .contact-row:last-child { border-bottom: 1px solid var(--line); }
  .contact-label {
    flex: none;
    width: 8rem;
    font-weight: 600;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .contact-note { margin-top: 1.75rem; font-size: 0.95rem; }
</style>
